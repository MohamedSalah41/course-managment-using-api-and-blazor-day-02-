@page "/trainees/{Id:int}/edit"
@inject TraineeService TraineeService
@inject TrackService TrackService
@inject NavigationManager Nav

<PageTitle>Edit Trainee</PageTitle>

@if (_notFound)
{
    <div class="alert alert-warning">
        <span class="bi bi-exclamation-triangle me-2"></span>
        Trainee with ID <strong>@Id</strong> was not found.
        <a href="/trainees" class="alert-link ms-2">Back to list</a>
    </div>
}
else if (_trainee is null)
{
    <LoadingSpinner Message="Loading trainee..." />
}
else
{
    <h1>Edit Trainee</h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <EditForm Model="_trainee" OnValidSubmit="HandleSubmit" OnInvalidSubmit="HandleInvalidSubmit">
                        <DataAnnotationsValidator />

                        @if (_showErrors)
                        {
                            <ValidationSummary />
                        }

                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="name">Full Name <span class="text-danger">*</span></label>
                            <InputText id="name" class="form-control" @bind-Value="_trainee.Name" />
                            <ValidationMessage For="() => _trainee.Name" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="gender">Gender <span class="text-danger">*</span></label>
                            <InputSelect id="gender" class="form-select" @bind-Value="_trainee.Gender">
                                <option value="">— Select Gender —</option>
                                @foreach (var g in Enum.GetValues<Gender>())
                                {
                                    <option value="@g">@g</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="() => _trainee.Gender" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="email">Email <span class="text-danger">*</span></label>
                            <InputText id="email" type="email" class="form-control" @bind-Value="_trainee.Email" />
                            <ValidationMessage For="() => _trainee.Email" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="mobile">Mobile No <span class="text-danger">*</span></label>
                            <InputText id="mobile" type="tel" class="form-control" @bind-Value="_trainee.MobileNo" />
                            <ValidationMessage For="() => _trainee.MobileNo" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="birthdate">Birthdate <span class="text-danger">*</span></label>
                            <InputDate id="birthdate" class="form-control" @bind-Value="_trainee.Birthdate" />
                            <ValidationMessage For="() => _trainee.Birthdate" class="text-danger small" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="track">Track</label>
                            <InputSelect id="track" class="form-select" @bind-Value="_trainee.TrackId">
                                <option value="">— No Track —</option>
                                @foreach (var track in _tracks)
                                {
                                    <option value="@track.Id">@track.Name</option>
                                }
                            </InputSelect>
                        </div>

                        <div class="mb-4 form-check">
                            <InputCheckbox id="graduated" class="form-check-input" @bind-Value="_trainee.IsGraduated" />
                            <label class="form-check-label" for="graduated">Mark as Graduated</label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <span class="bi bi-check-circle me-1"></span> Save Changes
                            </button>
                            <a href="/trainee-profile/@Id" class="btn btn-outline-secondary">
                                <span class="bi bi-eye me-1"></span> View Profile
                            </a>
                            <a href="/trainees" class="btn btn-outline-secondary">
                                <span class="bi bi-arrow-left me-1"></span> Cancel
                            </a>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Trainee? _trainee;
    private List<Track> _tracks = new();
    private bool _notFound;
    private bool _showErrors;

    protected override void OnParametersSet()
    {
        _tracks = TrackService.GetAll();

        var found = TraineeService.GetById(Id);
        if (found is null)
        {
            _notFound = true;
            return;
        }

        _trainee = new Trainee
        {
            Id          = found.Id,
            Name        = found.Name,
            Gender      = found.Gender,
            Email       = found.Email,
            MobileNo    = found.MobileNo,
            Birthdate   = found.Birthdate,
            IsGraduated = found.IsGraduated,
            TrackId     = found.TrackId
        };
    }

    private void HandleSubmit()
    {
        TraineeService.Update(_trainee!);
        Nav.NavigateTo("/trainees");
    }

    private void HandleInvalidSubmit() => _showErrors = true;
}
