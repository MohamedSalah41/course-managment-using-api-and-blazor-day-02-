@page "/tracks/create"
@inject TrackService TrackService
@inject NavigationManager Nav

<PageTitle>New Track</PageTitle>

<h1>New Track</h1>

<div class="row">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <EditForm Model="_track" OnValidSubmit="HandleSubmit" OnInvalidSubmit="HandleInvalidSubmit">
                    <DataAnnotationsValidator />

                    @if (_showErrors)
                    {
                        <ValidationSummary />
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold" for="name">Track Name <span class="text-danger">*</span></label>
                        <InputText id="name" class="form-control" @bind-Value="_track.Name" placeholder="e.g. Full Stack Web Development" />
                        <ValidationMessage For="() => _track.Name" class="text-danger small" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold" for="description">Description</label>
                        <InputTextArea id="description" class="form-control" @bind-Value="_track.Description"
                                       rows="4" placeholder="Brief description of the track..." />
                        <ValidationMessage For="() => _track.Description" class="text-danger small" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <span class="bi bi-check-circle me-1"></span> Create Track
                        </button>
                        <a href="/tracks" class="btn btn-outline-secondary">
                            <span class="bi bi-arrow-left me-1"></span> Cancel
                        </a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private Track _track = new();
    private bool _showErrors;

    private void HandleSubmit()
    {
        TrackService.Add(_track);
        Nav.NavigateTo("/tracks");
    }

    private void HandleInvalidSubmit() => _showErrors = true;
}
